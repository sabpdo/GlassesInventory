# Copy to .env (gitignored) for local development.
#
# DATABASE_URL: a Neon Postgres connection string. Use a Neon BRANCH for
# local dev so you don't touch prod data. Always use the POOLED URL
# (hostname ends with `-pooler.<region>.aws.neon.tech`) — required for
# serverless and recommended even locally.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"

# NextAuth (run: openssl rand -base64 32)
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Google OAuth (leave blank to disable Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Comma-separated list of emails that get admin privileges (see the "Team"
# tab in the navbar — full visibility into every user, what they've added,
# and what they've sold). The owner email is included by default in code.
ADMIN_EMAILS="FILLMEOUT"
