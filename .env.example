# Copy to .env (gitignored) for local development.
#
# DATABASE_URL: a Neon Postgres connection string. Use a Neon BRANCH for
# local dev so you don't touch prod data. Always use the POOLED URL
# (hostname ends with `-pooler.<region>.aws.neon.tech`) — required for
# serverless and recommended even locally.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"

# NextAuth (run: openssl rand -base64 32)
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Primary admin account (created/updated automatically on sign-in).
# Use an email or a username — public registration is off.
ADMIN_EMAIL="owner@shop.com"
ADMIN_PASSWORD="change-me-to-a-long-password"
ADMIN_NAME="Shop Owner"

# Optional: additional admin logins (comma-separated emails or usernames).
# They must already exist as user rows — use the Team page to create them
# first, then list their login here for admin privileges.
# ADMIN_EMAILS="manager@shop.com, jane"

# Optional: public URL phones use for QR pairing (defaults to NEXTAUTH_URL).
# Set this on Vercel to https://your-app.vercel.app so phone pairing works
# when the desktop browser shows a different hostname.
# NEXT_PUBLIC_APP_URL="https://md-glasses-inventory.vercel.app"

# Google only works for accounts the admin has already created.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
